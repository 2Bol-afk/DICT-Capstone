-
-        let plots = [];
-        let selectedPlotId = null;
-        let latestReadingId = null;
-        let map = null;
-        let markers = [];
-        let farmPolygons = [];
-        let addPlotMapObj = null;
-        let pendingVertices = [];
-        let vertexMarkers = [];
-        let pendingPolygon = null;
-        let pendingHectares = null;
-        let shapeFinished = false;
-
-        function pinColor(plot) {
-            const hasReading = plot.soil_n !== null && plot.soil_n !== undefined;
-            return hasReading ? "#2e7d32" : "#9ca3af";
-        }
-
-        const SENSOR_ZOOM_THRESHOLD = 14; // below this, show one pin per farm instead of every sensor
-
-        function sensorIconUrl(color) {
-            const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24">
-                <circle cx="12" cy="16" r="3.2" fill="${color}" stroke="#fff" stroke-width="1"/>
-                <path d="M7.5 12.5a6.5 6.5 0 0 1 9 0" stroke="${color}" stroke-width="2" fill="none" stroke-linecap="round"/>
-                <path d="M4.5 9a10.5 10.5 0 0 1 15 0" stroke="${color}" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.55"/>
-            </svg>`;
-            return "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg);
-        }
-
-        function buildSensorLegend() {
-            const items = [
-                ["#2e7d32", "May Reading ang Sensor / Sensor has a Reading"],
-                ["#9ca3af", "Walang Reading / No Reading Yet"],
-            ];
-            document.getElementById("legendSensorItems").innerHTML = items.map(([color, label]) => `
-                <div class="flex items-center gap-3 text-label-sm whitespace-nowrap">
-                    <img class="w-5 h-5 shrink-0" src="${sensorIconUrl(color)}">
-                    <span>${label}</span>
-                </div>
-            `).join("");
-        }
-
-        function farmCentroid(farm) {
-            const lats = farm.polygon.map(p => p[0]);
-            const lngs = farm.polygon.map(p => p[1]);
-            return { lat: lats.reduce((a, b) => a + b, 0) / lats.length, lng: lngs.reduce((a, b) => a + b, 0) / lngs.length };
-        }
-
-        function updateMapZoomView() {
-            const zoomedIn = map.getZoom() >= SENSOR_ZOOM_THRESHOLD;
-            markers.forEach(m => m.setMap(zoomedIn ? map : null));
-            farmMarkers.forEach(m => m.setMap(zoomedIn ? null : map));
-            document.getElementById("legendSensorItems").classList.toggle("hidden", !zoomedIn);
-            document.getElementById("legendFarmItems").classList.toggle("hidden", zoomedIn);
-        }
-
-        function setStatus(msg) {
-            document.getElementById("statusMsg").textContent = msg;
-        }
-
-        function initMaps() {
-            map = new google.maps.Map(document.getElementById("map"), {
-                center: PH_CENTER,
-                zoom: 6,
-                zoomControlOptions: { position: google.maps.ControlPosition.RIGHT_BOTTOM },
-                streetViewControl: false,
-            });
-            addPlotMapObj = new google.maps.Map(document.getElementById("addPlotMapDiv"), {
-                center: PH_CENTER,
-                zoom: 6,
-                zoomControlOptions: { position: google.maps.ControlPosition.RIGHT_BOTTOM },
-                mapTypeControlOptions: { position: google.maps.ControlPosition.TOP_RIGHT },
-                streetViewControl: false,
-            });
-
-            // ponytail: DrawingManager was removed from Maps JS (v3.65+) — place vertices by hand instead
-            addPlotMapObj.addListener("click", (e) => {
-                if (shapeFinished) return;
-                pendingVertices.push({ lat: e.latLng.lat(), lng: e.latLng.lng() });
-                redrawPendingShape();
-            });
-
-            map.addListener("zoom_changed", updateMapZoomView);
-            buildSensorLegend();
-            updateMapZoomView();
-
-            loadPlots().catch(() => setStatus("Could not reach backend at " + API));
-            loadFarms().catch(() => {});
-        }
-
-        function redrawPendingShape() {
-            if (pendingPolygon) pendingPolygon.setMap(null);
-            vertexMarkers.forEach(m => m.setMap(null));
-            vertexMarkers = pendingVertices.map(v => new google.maps.Marker({
-                position: v, map: addPlotMapObj,
-                icon: { path: google.maps.SymbolPath.CIRCLE, scale: 5, fillColor: "#2e7d32", fillOpacity: 1, strokeWeight: 0 },
-            }));
-            pendingPolygon = pendingVertices.length >= 2
-                ? new google.maps.Polygon({
-                    paths: pendingVertices, map: addPlotMapObj,
-                    fillColor: "#2e7d32", fillOpacity: 0.2, strokeColor: "#2e7d32", strokeWeight: 2,
-                })
-                : null;
-        }
-
-        document.getElementById("finishShapeBtn").addEventListener("click", () => {
-            if (pendingVertices.length < 3) { alert("Place at least 3 points to form a shape."); return; }
-            shapeFinished = true;
-            pendingHectares = google.maps.geometry.spherical.computeArea(pendingVertices) / 10000;
-            const sensorCount = Math.min(30, Math.max(1, Math.round(pendingHectares * 5)));
-            document.getElementById("addPlotLatLng").textContent = `Hectares: ${pendingHectares.toFixed(2)}`;
-            const info = document.getElementById("addPlotSensorInfo");
