-        // --- Settings: theme + language ---
-        // ponytail: bilingual labels are hardcoded as "Tagalog / English" text — split them
-        // generically at runtime instead of hand-wrapping every string in spans.
-        function wrapBilingualText(root) {
-            const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
-            const nodes = [];
-            let n;
-            while ((n = walker.nextNode())) nodes.push(n);
-            for (const node of nodes) {
-                const text = node.nodeValue;
-                const idx = text.indexOf(" / ");
-                if (idx === -1 || !node.parentNode || node.parentNode.closest("script, style")) continue;
-                const filSpan = document.createElement("span");
-                filSpan.className = "lang-fil";
-                filSpan.textContent = text.slice(0, idx);
-                const sepSpan = document.createElement("span");
-                sepSpan.className = "lang-sep";
-                sepSpan.textContent = " / ";
-                const enSpan = document.createElement("span");
-                enSpan.className = "lang-en";
-                enSpan.textContent = text.slice(idx + 3);
-                const parent = node.parentNode;
-                parent.insertBefore(filSpan, node);
-                parent.insertBefore(sepSpan, node);
-                parent.insertBefore(enSpan, node);
-                parent.removeChild(node);
-            }
-        }
-
-        function applyLanguage(pref) {
-            document.querySelectorAll(".lang-fil").forEach(el => el.style.display = pref === "en" ? "none" : "");
-            document.querySelectorAll(".lang-en, span.italic").forEach(el => el.style.display = pref === "fil" ? "none" : "");
-            document.querySelectorAll(".lang-sep").forEach(el => el.style.display = pref === "both" ? "" : "none");
-        }
-
-        function applyTheme(theme) {
-            document.documentElement.classList.toggle("dark", theme === "dark");
-        }
-
-        wrapBilingualText(document.body);
