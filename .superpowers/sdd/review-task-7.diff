-        }
-
-        // --- Farm Detail modal (Edit/Delete, incl. boundary/location redraw) ---
-        const farmDetailModal = document.getElementById("farmDetailModal");
-        let selectedFarmId = null;
-        let farmDetailMapObj = null;
-        let detailVertices = [];
-        let detailVertexMarkers = [];
-        let detailPolygonOverlay = null;
-        let detailHectares = null;
