-
-        let plots = [];
-        let selectedPlotId = null;
-        let latestReadingId = null;
-        let map = null;
-        let markers = [];
-        let farmPolygons = [];
-        let addPlotMapObj = null;
-        let pendingVertices = [];
-        let vertexMarkers = [];
-        let pendingPolygon = null;
-        let pendingHectares = null;
