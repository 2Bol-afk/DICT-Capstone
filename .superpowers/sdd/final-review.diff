+    // skip inputs / selects
+    if (el.tagName === "INPUT" || el.tagName === "SELECT" || el.tagName === "OPTION") return;
+    el.textContent = pref === "en" ? (el.dataset.en || el.dataset.fil) : el.dataset.fil;
+  });
+  // Update lang toggle
+  const toggle = document.getElementById("langToggle");
+  toggle.textContent = pref === "fil" ? "EN" : "FIL";
+  // Update active states in Settings
+  document.querySelectorAll(".lang-option").forEach(b => b.classList.toggle("active", b.dataset.lang === pref));
+  // Refresh any displayed crop labels
+  if (currentSensorEn) {
+    document.getElementById("sensorRecCrop").textContent = cropLabel(currentSensorEn);
+  }
+}
+
+// ===== THEME =====
+function applyTheme(theme) {
+  document.documentElement.classList.toggle("dark", theme === "dark");
+  localStorage.setItem("theme", theme);
+  document.querySelectorAll(".theme-option").forEach(b => b.classList.toggle("active", b.dataset.theme === theme));
+}
+
+// ===== TAB NAVIGATION =====
+const ALL_TABS = ["tabMyFarms", "tabSensors", "tabHistory", "tabSettings"];
+
+function setTab(tabId) {
+  ALL_TABS.forEach(id => {
+    document.getElementById(id).classList.toggle("hidden", id !== tabId);
+  });
+  document.querySelectorAll(".nav-btn").forEach(b => {
+    b.classList.toggle("active", b.dataset.tab === tabId);
+  });
+}
+
+document.querySelectorAll(".nav-btn").forEach(btn => {
+  btn.addEventListener("click", () => setTab(btn.dataset.tab));
+});
+
+// ===== LOAD MY FARMS =====
+async function loadMyFarms() {
+  const container = document.getElementById("farmCardList");
+  container.innerHTML = "";
+  for (const farm of farmerAuth.farms) {
+    const card = buildFarmCardSkeleton(farm);
+    container.appendChild(card);
+    fetchFarmPredict(farm);
+  }
+}
+
+function buildFarmCardSkeleton(farm) {
+  const card = document.createElement("div");
+  card.className = "bg-white rounded-2xl shadow-sm border border-gray-100 p-4 cursor-pointer active:scale-[0.98] transition-transform";
+  card.setAttribute("data-farm-id", farm.farm_id);
+
+  const inner = document.createElement("div");
+  inner.className = "flex items-start gap-3";
+
+  const iconWrap = document.createElement("div");
+  iconWrap.className = "w-10 h-10 rounded-xl bg-[#e8f5e9] flex items-center justify-center flex-shrink-0";
+  const icon = document.createElement("span");
+  icon.className = "material-symbols-outlined text-[#0d631b]";
+  icon.style.fontVariationSettings = "'FILL' 1,'wght' 500,'GRAD' 0,'opsz' 24";
+  icon.textContent = "yard";
+  iconWrap.appendChild(icon);
+
+  const info = document.createElement("div");
+  info.className = "flex-1 min-w-0";
+  const nameEl = document.createElement("p");
+  nameEl.className = "font-bold text-sm truncate";
+  nameEl.textContent = farm.farm_name;
+  const sensorCount = document.createElement("p");
+  sensorCount.className = "text-xs text-gray-400";
+  sensorCount.textContent = `${farm.sensors.length} sensor${farm.sensors.length !== 1 ? "s" : ""}`;
+  info.appendChild(nameEl);
+  info.appendChild(sensorCount);
+
+  const recWrap = document.createElement("div");
+  recWrap.className = "text-right flex-shrink-0";
+  const recLabel = document.createElement("p");
+  recLabel.className = "text-[10px] font-bold text-gray-400 uppercase mb-0.5";
+  recLabel.textContent = lang === "en" ? "Recommendation" : "Rekomendasyon";
+  const recCrop = document.createElement("p");
+  recCrop.className = "text-sm font-bold text-[#0d631b]";
+  recCrop.id = `farmRec_${farm.farm_id}`;
+  recCrop.textContent = "…";
+  const recConf = document.createElement("p");
+  recConf.className = "text-xs text-gray-400";
+  recConf.id = `farmConf_${farm.farm_id}`;
+  recWrap.appendChild(recLabel);
+  recWrap.appendChild(recCrop);
+  recWrap.appendChild(recConf);
+
+  inner.appendChild(iconWrap);
+  inner.appendChild(info);
+  inner.appendChild(recWrap);
+  card.appendChild(inner);
+
+  // Click: switch to sensors tab
+  card.addEventListener("click", () => {
+    setTab("tabSensors");
+    const sel = document.getElementById("sensorFarmSelect");
+    sel.value = farm.farm_id;
+    loadSensors(farm.farm_id);
+  });
+
+  return card;
+}
+
+async function fetchFarmPredict(farm) {
+  try {
+    const res = await fetch(`${API}/farms/${encodeURIComponent(farm.farm_id)}/predict`);
+    if (!res.ok) return;
+    const data = await res.json();
+    const cropEl = document.getElementById(`farmRec_${farm.farm_id}`);
+    const confEl = document.getElementById(`farmConf_${farm.farm_id}`);
+    if (!cropEl) return;
+    if (data.crop) {
+      cropEl.textContent = cropLabel(data.crop);
+      cropEl.setAttribute("data-crop-en", data.crop);
+      if (confEl) confEl.textContent = `${Math.round((data.confidence || 0) * 100)}%`;
+    } else {
+      cropEl.textContent = lang === "en" ? "No match" : "Walang katugma";
+      if (confEl) confEl.textContent = "";
+    }
+  } catch {
+    // silently ignore network errors on cards
+  }
+}
+
+// ===== LOAD SENSORS TAB =====
+async function loadSensors(farmId) {
+  currentSensorFarmId = farmId;
+  currentSensorEn = null;
+
+  // Reset UI
+  document.getElementById("sensorRecCard").classList.add("hidden");
+  document.getElementById("sensorBtnWrap").classList.add("hidden");
+  document.getElementById("sensorReadingsWrap").classList.add("hidden");
+  document.getElementById("sensorExplainText").textContent = "";
+  document.getElementById("sensorExplainBtn").classList.add("hidden");
+  document.getElementById("sensorBtnList").innerHTML = "";
+  clearReadings();
+
+  const farm = farmerAuth.farms.find(f => f.farm_id === farmId);
+  if (!farm) return;
+
+  // Fetch predict
+  try {
+    const res = await fetch(`${API}/farms/${encodeURIComponent(farmId)}/predict`);
+    if (res.ok) {
+      const data = await res.json();
+      currentSensorEn = data.crop || null;
+      const recCard = document.getElementById("sensorRecCard");
+      document.getElementById("sensorRecCrop").textContent = data.crop ? cropLabel(data.crop) : (lang === "en" ? "No match" : "Walang katugma");
+      document.getElementById("sensorRecConf").textContent = data.crop ? `${Math.round((data.confidence || 0) * 100)}% confidence` : "";
+      if (data.crop) {
+        document.getElementById("sensorExplainBtn").classList.remove("hidden");
+      }
+      recCard.classList.remove("hidden");
+    }
+  } catch { /* ignore */ }
+
+  // Build sensor buttons
+  if (farm.sensors.length) {
+    const btnList = document.getElementById("sensorBtnList");
+    farm.sensors.forEach((sensor, i) => {
+      const hasReading = sensor.soil_n !== null && sensor.soil_n !== undefined;
+      const btn = document.createElement("button");
+      btn.type = "button";
+      btn.className = "sensor-btn border rounded-xl px-3 py-2 text-sm font-bold flex items-center gap-2 " +
+        (hasReading
+          ? "text-[#0d631b] border-[#0d631b]"
+          : "text-gray-400 border-gray-300");
+      const dot = document.createElement("span");
+      dot.className = "inline-block w-2 h-2 rounded-full";
+      dot.style.background = hasReading ? "#0d631b" : "#9ca3af";
+      btn.appendChild(dot);
+      btn.appendChild(document.createTextNode(`Sensor ${i + 1}`));
+      btn.addEventListener("click", () => {
+        document.querySelectorAll(".sensor-btn").forEach(b => b.classList.remove("active"));
+        btn.classList.add("active");
+        showReading(sensor);
+      });
+      btnList.appendChild(btn);
+    });
+    document.getElementById("sensorBtnWrap").classList.remove("hidden");
+
+    // Auto-show first sensor with reading
+    const first = farm.sensors.find(s => s.soil_n !== null && s.soil_n !== undefined) || farm.sensors[0];
+    if (first) {
+      const firstBtn = btnList.children[farm.sensors.indexOf(first)];
+      if (firstBtn) firstBtn.classList.add("active");
+      showReading(first);
+    }
+  }
+}
+
+function clearReadings() {
+  ["rN","rP","rK","rPh","rTemp","rRain"].forEach(id => {
+    document.getElementById(id).textContent = "—";
+  });
+  document.getElementById("sensorTimestamp").textContent = "";
+}
+
+function showReading(sensor) {
+  const wrap = document.getElementById("sensorReadingsWrap");
+  if (!sensor || (sensor.soil_n === null || sensor.soil_n === undefined)) {
+    clearReadings();
+    wrap.classList.remove("hidden");
+    return;
+  }
+  document.getElementById("rN").textContent = sensor.soil_n ?? "—";
+  document.getElementById("rP").textContent = sensor.soil_p ?? "—";
+  document.getElementById("rK").textContent = sensor.soil_k ?? "—";
+  document.getElementById("rPh").textContent = sensor.soil_ph ?? "—";
+  document.getElementById("rTemp").textContent = sensor.air_temp_c != null ? `${sensor.air_temp_c}°C` : "—";
+  document.getElementById("rRain").textContent = sensor.rainfall_mm != null ? `${sensor.rainfall_mm}mm` : "—";
+  if (sensor.timestamp) {
+    document.getElementById("sensorTimestamp").textContent = `Updated: ${new Date(sensor.timestamp).toLocaleString()}`;
+  }
+  wrap.classList.remove("hidden");
+}
+
+// ===== EXPLAIN BUTTON (Sensors tab) =====
+document.getElementById("sensorExplainBtn").addEventListener("click", async function () {
+  if (!currentSensorFarmId) return;
+  const btn = this;
+  btn.textContent = lang === "en" ? "Thinking..." : "Sandali lang...";
+  btn.disabled = true;
+  document.getElementById("sensorExplainText").textContent = "";
+  try {
+    const res = await fetch(`${API}/farms/${encodeURIComponent(currentSensorFarmId)}/explain?lang=${lang}`);
+    const data = await res.json();
+    document.getElementById("sensorExplainText").textContent = data.explanation || data.detail || (lang === "en" ? "No explanation available." : "Walang paliwanag.");
+  } catch {
+    document.getElementById("sensorExplainText").textContent = lang === "en" ? "Could not reach the AI model." : "Hindi maabot ang AI model.";
+  }
+  btn.textContent = lang === "en" ? (btn.dataset.en || "Why?") : (btn.dataset.fil || "Bakit?");
+  btn.disabled = false;
+});
+
+// ===== LOAD HISTORY TAB =====
+async function loadHistory(farmId) {
+  const body = document.getElementById("historyBody");
+  body.innerHTML = `<tr><td colspan="4" class="py-4 text-center text-sm text-gray-400">${lang === "en" ? "Loading..." : "Naglo-load..."}</td></tr>`;
+  const farm = farmerAuth.farms.find(f => f.farm_id === farmId);
+  if (!farm || !farm.sensors.length) {
+    body.innerHTML = `<tr><td colspan="4" class="py-6 text-center text-sm text-gray-400">${lang === "en" ? "No sensors." : "Walang sensor."}</td></tr>`;
+    return;
+  }
+  // Fetch readings for each sensor and collect all rows
+  const rows = [];
+  await Promise.all(farm.sensors.map(async sensor => {
+    try {
+      const res = await fetch(`${API}/readings/${encodeURIComponent(sensor.plot_id)}`);
+      if (!res.ok) return;
+      const readings = await res.json();
+      readings.filter(r => r.soil_n !== null && r.soil_n !== undefined).forEach(r => rows.push(r));
+    } catch { /* ignore */ }
+  }));
+
+  if (!rows.length) {
+    body.innerHTML = `<tr><td colspan="4" class="py-6 text-center text-sm text-gray-400">${lang === "en" ? "No readings yet." : "Wala pang datos."}</td></tr>`;
+    return;
+  }
+
+  // Sort descending by timestamp
+  rows.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
+
+  body.innerHTML = "";
+  for (const r of rows.slice(0, 20)) {
+    const tr = document.createElement("tr");
+    tr.className = "border-t border-gray-100";
+    const date = document.createElement("td");
+    date.className = "py-2 px-4 text-xs text-gray-600";
+    date.textContent = new Date(r.timestamp).toLocaleDateString();
+    const ph = document.createElement("td");
+    ph.className = "py-2 px-4 text-xs";
+    ph.textContent = r.soil_ph ?? "—";
+    const temp = document.createElement("td");
+    temp.className = "py-2 px-4 text-xs";
+    temp.textContent = r.air_temp_c != null ? `${r.air_temp_c}°C` : "—";
+    const crop = document.createElement("td");
+    crop.className = "py-2 px-4 text-xs font-medium text-[#0d631b]";
+    crop.textContent = r.predicted_crop ? cropLabel(r.predicted_crop) : "—";
+    tr.appendChild(date);
+    tr.appendChild(ph);
+    tr.appendChild(temp);
+    tr.appendChild(crop);
+    body.appendChild(tr);
+  }
+}
+
+// ===== FARM SELECTS =====
+function populateFarmSelects() {
+  ["sensorFarmSelect", "historyFarmSelect"].forEach(selectId => {
+    const sel = document.getElementById(selectId);
+    sel.innerHTML = "";
+    farmerAuth.farms.forEach(farm => {
+      const opt = document.createElement("option");
+      opt.value = farm.farm_id;
+      opt.textContent = farm.farm_name;
+      sel.appendChild(opt);
+    });
+  });
+}
+
+document.getElementById("sensorFarmSelect").addEventListener("change", function () {
+  loadSensors(this.value);
+});
+
+document.getElementById("historyFarmSelect").addEventListener("change", function () {
+  loadHistory(this.value);
+});
+
+// History tab nav button — auto-load on first visit
+document.querySelectorAll(".nav-btn").forEach(btn => {
+  if (btn.dataset.tab === "tabHistory") {
+    btn.addEventListener("click", () => {
+      const sel = document.getElementById("historyFarmSelect");
+      if (sel.value) loadHistory(sel.value);
+    });
+  }
+  if (btn.dataset.tab === "tabSensors") {
+    btn.addEventListener("click", () => {
+      const sel = document.getElementById("sensorFarmSelect");
+      if (sel.value && !currentSensorFarmId) loadSensors(sel.value);
+    });
+  }
+});
+
+// ===== SETTINGS =====
+document.querySelectorAll(".lang-option").forEach(btn => {
+  btn.addEventListener("click", () => applyLanguage(btn.dataset.lang));
+});
+
+document.querySelectorAll(".theme-option").forEach(btn => {
+  btn.addEventListener("click", () => applyTheme(btn.dataset.theme));
+});
+
+document.getElementById("langToggle").addEventListener("click", () => {
+  applyLanguage(lang === "fil" ? "en" : "fil");
+});
+
+document.getElementById("logoutBtn").addEventListener("click", () => {
+  sessionStorage.removeItem("farmerAuth");
+  window.location.replace("/");
+});
+
+// ===== INIT =====
+(function init() {
+  // Farmer name in header
+  document.getElementById("headerFarmerName").textContent = farmerAuth.name || farmerAuth.id || "";
+
+  // Populate selects
+  populateFarmSelects();
+
+  // Apply saved theme & language
+  const savedTheme = localStorage.getItem("theme") || "light";
+  applyTheme(savedTheme);
+  applyLanguage(lang);
+
+  // Mark correct theme option active
+  document.querySelectorAll(".theme-option").forEach(b => b.classList.toggle("active", b.dataset.theme === savedTheme));
+
+  // Load My Farms tab
+  loadMyFarms();
+
+  // Auto-load first farm in sensors
+  if (farmerAuth.farms.length) {
+    loadSensors(farmerAuth.farms[0].farm_id);
+  }
+})();
+</script>
+</body>
+</html>
