+
+<!-- ==================== SCRIPTS ==================== -->
+<script>
+  const API = "";
+
+  let farmers = [], farms = [], map, farmPolygons = [];
+  let editingFarmerId = null, assigningFarmId = null, deleteCb = null;
+
+  // ─── Tab switching ───────────────────────────────────────────────────────────
+  function setTab(id) {
+    ["tabDashboard","tabFarmers","tabFarms"].forEach(t => {
+      document.getElementById(t).classList.toggle("hidden", t !== id);
+    });
+    document.querySelectorAll(".nav-btn").forEach(b => {
+      b.classList.toggle("active", b.dataset.tab === id);
+    });
+    if (id === "tabDashboard") loadDashboard();
+    if (id === "tabFarmers")   loadFarmers();
+    if (id === "tabFarms")     loadFarmsTab();
+  }
+
+  document.querySelectorAll(".nav-btn").forEach(b =>
+    b.addEventListener("click", () => setTab(b.dataset.tab))
+  );
+
+  document.getElementById("logoutBtn").addEventListener("click", () => {
+    sessionStorage.removeItem("adminAuth");
+    window.location.href = "/";
+  });
+
+  // ─── Google Maps init (called by Maps API callback) ─────────────────────────
+  window.initMap = function () {
+    map = new google.maps.Map(document.getElementById("map"), {
+      center: { lat: 12.8797, lng: 121.7740 },
+      zoom: 6,
+      mapTypeId: "satellite",
+      streetViewControl: false,
+      mapTypeControlOptions: { position: google.maps.ControlPosition.TOP_RIGHT },
+    });
+    loadDashboard();
+  };
+
+  function renderMap(fms) {
+    farmPolygons.forEach(p => p.setMap(null));
+    farmPolygons = fms
+      .filter(f => Array.isArray(f.polygon) && f.polygon.length >= 3)
+      .map(f => {
+        const poly = new google.maps.Polygon({
+          paths: f.polygon.map(([lat, lng]) => ({ lat, lng })),
+          map,
+          fillColor: "#22c55e",
+          fillOpacity: 0.25,
+          strokeColor: "#16a34a",
+          strokeWeight: 2,
+        });
+        return poly;
+      });
+
+    if (fms.length) {
+      const bounds = new google.maps.LatLngBounds();
+      fms.forEach(f => {
+        if (Array.isArray(f.polygon)) {
+          f.polygon.forEach(([lat, lng]) => bounds.extend({ lat, lng }));
+        }
+      });
+      if (!bounds.isEmpty()) map.fitBounds(bounds);
+    }
+  }
+
+  // ─── Dashboard ───────────────────────────────────────────────────────────────
+  async function loadDashboard() {
+    try {
+      const [fRes, fmRes] = await Promise.all([
+        fetch(`${API}/farmers`),
+        fetch(`${API}/farms`),
+      ]);
+      farmers = await fRes.json();
+      farms   = await fmRes.json();
+    } catch {
+      return;
+    }
+
+    document.getElementById("statFarmers").textContent = farmers.length;
+    document.getElementById("statFarms").textContent   = farms.length;
+
+    // Count farms with at least one reading
+    let sensorsWithReading = 0;
+    const readingChecks = farms.map(async f => {
+      try {
+        const r = await fetch(`${API}/readings/${encodeURIComponent(f.farm_id)}`);
+        if (!r.ok) return;
+        const readings = await r.json();
+        if (Array.isArray(readings) && readings.length > 0) sensorsWithReading++;
+      } catch {}
+    });
+    await Promise.all(readingChecks);
+    document.getElementById("statSensors").textContent = sensorsWithReading;
+
+    // Map polygons
+    if (map) renderMap(farms);
+
+    // Overview table
+    const farmerMap = Object.fromEntries(farmers.map(f => [f.id, f.name]));
+    const tbody = document.getElementById("dashFarmBody");
+    if (!farms.length) {
+      tbody.innerHTML = `<tr><td colspan="4" class="px-6 py-8 text-center text-gray-400">Walang bukid pa.</td></tr>`;
+      return;
+    }
+
+    const rows = await Promise.all(farms.map(async f => {
+      let sensorCount = 0, rec = "—";
+      try {
+        const r = await fetch(`${API}/readings/${encodeURIComponent(f.farm_id)}`);
+        if (r.ok) {
+          const readings = await r.json();
+          sensorCount = Array.isArray(readings) ? readings.length : 0;
+        }
+      } catch {}
+      try {
+        const r = await fetch(`${API}/farms/${encodeURIComponent(f.farm_id)}/predict`);
+        if (r.ok) {
+          const d = await r.json();
+          if (d.crop) rec = d.crop;
+        }
+      } catch {}
+      const farmerName = farmerMap[f.farmer_id] || "—";
+      return `<tr class="hover:bg-gray-50 transition">
+        <td class="px-6 py-4 font-medium text-gray-800">${esc(f.farm_name || f.farm_id)}</td>
+        <td class="px-6 py-4 text-gray-600">${esc(farmerName)}</td>
+        <td class="px-6 py-4 text-gray-600">${sensorCount}</td>
+        <td class="px-6 py-4">
+          ${rec !== "—"
+            ? `<span class="inline-flex items-center gap-1 bg-[#f0fdf4] text-[#0d631b] text-xs font-bold px-2.5 py-1 rounded-full">${esc(rec)}</span>`
+            : `<span class="text-gray-400 text-xs">—</span>`}
+        </td>
+      </tr>`;
+    }));
+
+    tbody.innerHTML = rows.join("");
+  }
+
+  // ─── Farmers tab ─────────────────────────────────────────────────────────────
+  async function loadFarmers() {
+    try {
+      const [fRes, fmRes] = await Promise.all([
+        fetch(`${API}/farmers`),
+        fetch(`${API}/farms`),
+      ]);
+      farmers = await fRes.json();
+      farms   = await fmRes.json();
+    } catch {
+      document.getElementById("farmersBody").innerHTML =
+        `<tr><td colspan="4" class="px-6 py-8 text-center text-red-400">Hindi ma-load ang data.</td></tr>`;
+      return;
+    }
+
+    const tbody = document.getElementById("farmersBody");
+    if (!farmers.length) {
+      tbody.innerHTML = `<tr><td colspan="4" class="px-6 py-8 text-center text-gray-400">Walang magsasaka pa.</td></tr>`;
+      return;
+    }
+
+    tbody.innerHTML = "";
+    farmers.forEach(f => {
+      const farmCount = farms.filter(fm => fm.farmer_id === f.id || fm.farmer_id === String(f.id)).length;
+      const created = f.created_at
+        ? new Date(f.created_at).toLocaleDateString("fil-PH", { year:"numeric", month:"short", day:"numeric" })
+        : "—";
+      const tr = document.createElement("tr");
+      tr.className = "hover:bg-gray-50 transition";
+      tr.innerHTML = `
+        <td class="px-6 py-4 font-medium text-gray-800">${esc(f.name)}</td>
+        <td class="px-6 py-4 text-gray-600">${farmCount}</td>
+        <td class="px-6 py-4 text-gray-500">${created}</td>
+        <td class="px-6 py-4">
+          <div class="flex items-center gap-2">
+            <button class="edit-farmer-btn text-xs font-bold text-[#0d631b] border border-[#0d631b] px-3 py-1 rounded-lg hover:bg-[#f0fdf4] transition">I-edit</button>
+            <button class="del-farmer-btn text-xs font-bold text-red-600 border border-red-200 px-3 py-1 rounded-lg hover:bg-red-50 transition">Burahin</button>
+          </div>
+        </td>`;
+      tbody.appendChild(tr);
+      const editBtn = tr.querySelector(".edit-farmer-btn");
+      const delBtn  = tr.querySelector(".del-farmer-btn");
+      if (editBtn) editBtn.addEventListener("click", () => openFarmerModal(f.id, f.name));
+      if (delBtn)  delBtn.addEventListener("click",  () => confirmDelete(
+        `Burahin si "${f.name}"? Ang lahat ng kaugnayan sa bukid ay aalisin.`,
+        () => deleteFarmer(f.id)
+      ));
+    });
+  }
+
+  function openFarmerModal(id, name) {
+    editingFarmerId = id || null;
+    document.getElementById("farmerModalTitle").textContent =
+      id ? "I-edit ang Magsasaka" : "Magdagdag ng Magsasaka";
+    document.getElementById("farmerNameInput").value = name || "";
+    document.getElementById("farmerModalError").classList.add("hidden");
+    document.getElementById("farmerModalError").textContent = "";
+    document.getElementById("farmerModal").classList.remove("hidden");
+    document.getElementById("farmerNameInput").focus();
+  }
+
+  document.getElementById("addFarmerBtn").addEventListener("click", () => openFarmerModal(null, ""));
+  document.getElementById("farmerModalClose").addEventListener("click",  () => document.getElementById("farmerModal").classList.add("hidden"));
+  document.getElementById("farmerModalCancel").addEventListener("click", () => document.getElementById("farmerModal").classList.add("hidden"));
+
+  document.getElementById("farmerModalSave").addEventListener("click", async () => {
+    const name = document.getElementById("farmerNameInput").value.trim();
+    const errEl = document.getElementById("farmerModalError");
+    errEl.classList.add("hidden");
+
+    if (!name) { errEl.textContent = "Kailangan ang pangalan."; errEl.classList.remove("hidden"); return; }
+
+    try {
+      let res;
+      if (editingFarmerId) {
+        res = await fetch(`${API}/farmers/${editingFarmerId}`, {
+          method: "PUT",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify({ name }),
+        });
+      } else {
+        res = await fetch(`${API}/farmers`, {
+          method: "POST",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify({ name }),
+        });
+      }
+      if (res.status === 409) { errEl.textContent = "Mayroon na itong pangalan."; errEl.classList.remove("hidden"); return; }
+      if (!res.ok) { const d = await res.json().catch(() => ({})); errEl.textContent = d.detail || "May error."; errEl.classList.remove("hidden"); return; }
+      document.getElementById("farmerModal").classList.add("hidden");
+      await loadFarmers();
+    } catch {
+      errEl.textContent = "Hindi ma-konekta sa server."; errEl.classList.remove("hidden");
+    }
+  });
+
+  async function deleteFarmer(id) {
+    try {
+      await fetch(`${API}/farmers/${id}`, { method: "DELETE" });
+      await loadFarmers();
+    } catch {}
+  }
+
+  // ─── Farms tab ───────────────────────────────────────────────────────────────
+  async function loadFarmsTab() {
+    try {
+      const [fRes, fmRes] = await Promise.all([
+        fetch(`${API}/farms`),
+        fetch(`${API}/farmers`),
+      ]);
+      farms   = await fRes.json();
+      farmers = await fmRes.json();
+    } catch {
+      document.getElementById("farmsBody").innerHTML =
+        `<tr><td colspan="5" class="px-6 py-8 text-center text-red-400">Hindi ma-load ang data.</td></tr>`;
+      return;
+    }
+
+    const tbody = document.getElementById("farmsBody");
+    if (!farms.length) {
+      tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-8 text-center text-gray-400">Walang bukid pa.</td></tr>`;
+      return;
+    }
+
+    const farmerMap = Object.fromEntries(farmers.map(f => [String(f.id), f.name]));
+
+    const farmData = await Promise.all(farms.map(async f => {
+      let sensorCount = 0;
+      try {
+        const r = await fetch(`${API}/readings/${encodeURIComponent(f.farm_id)}`);
+        if (r.ok) {
+          const readings = await r.json();
+          sensorCount = Array.isArray(readings) ? readings.length : 0;
+        }
+      } catch {}
+      return { f, sensorCount };
+    }));
+
+    tbody.innerHTML = "";
+    farmData.forEach(({ f, sensorCount }) => {
+      const farmerName = f.farmer_id != null ? (farmerMap[String(f.farmer_id)] || "—") : "—";
+      const hectares   = f.hectares != null ? Number(f.hectares).toFixed(2) : "—";
+      const tr = document.createElement("tr");
+      tr.className = "hover:bg-gray-50 transition";
+      tr.innerHTML = `
+        <td class="px-6 py-4 font-medium text-gray-800">${esc(f.farm_name || f.farm_id)}</td>
+        <td class="px-6 py-4 text-gray-600">${esc(farmerName)}</td>
+        <td class="px-6 py-4 text-gray-600">${sensorCount}</td>
+        <td class="px-6 py-4 text-gray-600">${hectares} ha</td>
+        <td class="px-6 py-4">
+          <div class="flex items-center gap-2">
+            <button class="assign-farm-btn text-xs font-bold text-[#0d631b] border border-[#0d631b] px-3 py-1 rounded-lg hover:bg-[#f0fdf4] transition">I-assign</button>
+            <button class="del-farm-btn text-xs font-bold text-red-600 border border-red-200 px-3 py-1 rounded-lg hover:bg-red-50 transition">Burahin</button>
+          </div>
+        </td>`;
+      tbody.appendChild(tr);
+      const assignBtn = tr.querySelector(".assign-farm-btn");
+      const delBtn    = tr.querySelector(".del-farm-btn");
+      if (assignBtn) assignBtn.addEventListener("click", () =>
+        openFarmModal(f.farm_id, f.farm_name || f.farm_id, f.farmer_id != null ? String(f.farmer_id) : "")
+      );
+      if (delBtn) delBtn.addEventListener("click", () => confirmDelete(
+        `Burahin ang bukid na "${f.farm_name || f.farm_id}"? Hindi na ito mababawi.`,
+        () => deleteFarm(f.farm_id)
+      ));
+    });
+  }
+
+  function openFarmModal(farmId, farmName, currentFarmerId) {
+    assigningFarmId = farmId;
+    document.getElementById("farmModalName").textContent = farmName;
+    document.getElementById("farmModalError").classList.add("hidden");
+    document.getElementById("farmModalError").textContent = "";
+
+    // Populate farmer dropdown
+    const sel = document.getElementById("farmModalFarmerSelect");
+    sel.innerHTML = `<option value="">— Walang magsasaka —</option>`;
+    farmers.forEach(f => {
+      const opt = document.createElement("option");
+      opt.value = String(f.id);
+      opt.textContent = f.name;
+      if (String(f.id) === String(currentFarmerId)) opt.selected = true;
+      sel.appendChild(opt);
+    });
+
+    document.getElementById("farmModal").classList.remove("hidden");
+  }
+
+  const addFarmBtnEl = document.getElementById("addFarmBtn");
+  addFarmBtnEl.disabled = true;
+  addFarmBtnEl.title = "Hindi available — gamitin ang API o simulation program";
+  addFarmBtnEl.classList.add("opacity-50", "cursor-not-allowed");
+
+  document.getElementById("farmModalClose").addEventListener("click",  () => document.getElementById("farmModal").classList.add("hidden"));
+  document.getElementById("farmModalCancel").addEventListener("click", () => document.getElementById("farmModal").classList.add("hidden"));
+
+  document.getElementById("farmModalSave").addEventListener("click", async () => {
+    const farmerId = document.getElementById("farmModalFarmerSelect").value;
+    const errEl    = document.getElementById("farmModalError");
+    errEl.classList.add("hidden");
+
+    try {
+      const res = await fetch(`${API}/farms/${encodeURIComponent(assigningFarmId)}/farmer`, {
+        method: "PUT",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ farmer_id: farmerId || null }),
+      });
+      if (!res.ok) {
+        const d = await res.json().catch(() => ({}));
+        errEl.textContent = d.detail || "May error.";
+        errEl.classList.remove("hidden");
+        return;
+      }
+      document.getElementById("farmModal").classList.add("hidden");
+      await loadFarmsTab();
+    } catch {
+      errEl.textContent = "Hindi ma-konekta sa server.";
+      errEl.classList.remove("hidden");
+    }
+  });
+
+  async function deleteFarm(farmId) {
+    try {
+      await fetch(`${API}/farms/${encodeURIComponent(farmId)}`, { method: "DELETE" });
+      await loadFarmsTab();
+    } catch {}
+  }
+
+  // ─── Delete confirm modal ────────────────────────────────────────────────────
+  function confirmDelete(msg, cb) {
+    deleteCb = cb;
+    document.getElementById("deleteModalMsg").textContent = msg;
+    document.getElementById("deleteModal").classList.remove("hidden");
+  }
+
+  document.getElementById("deleteModalCancel").addEventListener("click", () => {
+    deleteCb = null;
+    document.getElementById("deleteModal").classList.add("hidden");
+  });
+
+  document.getElementById("deleteModalConfirm").addEventListener("click", () => {
+    document.getElementById("deleteModal").classList.add("hidden");
+    if (deleteCb) { deleteCb(); deleteCb = null; }
+  });
+
+  // ─── Utility ─────────────────────────────────────────────────────────────────
+  function esc(s) {
+    if (s == null) return "";
+    return String(s)
+      .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
+      .replace(/"/g,"&quot;").replace(/'/g,"&#39;");
+  }
+
+  // ─── Boot: show Dashboard tab ────────────────────────────────────────────────
+  setTab("tabDashboard");
+
+  // Dynamically inject Maps script so the API key comes from config.js
+  (function () {
+    const s = document.createElement("script");
+    s.async = true;
+    s.defer = true;
+    s.src = `https://maps.googleapis.com/maps/api/js?key=${GOOGLE_MAPS_API_KEY}&callback=initMap`;
+    document.head.appendChild(s);
+  })();
+</script>
+</body>
+</html>
