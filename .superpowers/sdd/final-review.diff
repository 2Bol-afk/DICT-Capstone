-
-        document.getElementById("clearShapeBtn").addEventListener("click", () => {
-            pendingVertices = [];
-            shapeFinished = false;
-            pendingHectares = null;
-            if (pendingPolygon) { pendingPolygon.setMap(null); pendingPolygon = null; }
-            vertexMarkers.forEach(m => m.setMap(null));
-            vertexMarkers = [];
-            document.getElementById("addPlotLatLng").textContent = "Click the map to place corner points (3+), then Finish Shape.";
-            document.getElementById("addPlotSensorInfo").classList.add("hidden");
-        });
-
-        document.getElementById("locateMeBtn").addEventListener("click", () => {
-            if (!navigator.geolocation) { setStatus("This browser has no geolocation support."); return; }
-            if (location.protocol === "file:") {
-                setStatus("Geolocation is blocked on file:// pages — serve this folder over http(s) instead.");
-                return;
-            }
-            navigator.geolocation.getCurrentPosition((pos) => {
-                const here = { lat: pos.coords.latitude, lng: pos.coords.longitude };
-                addPlotMapObj.setCenter(here);
-                addPlotMapObj.setZoom(17);
-            }, (err) => setStatus(`Could not get your location (${err.message}).`));
-        });
-
-        let farms = [];
-        let farmMarkers = [];
-
-        async function loadFarms() {
-            const res = await fetch(`${API}/farms`);
-            farms = await res.json();
-            farmPolygons.forEach(p => p.setMap(null));
-            farmPolygons = farms.map(farm => {
-                const poly = new google.maps.Polygon({
-                    paths: farm.polygon.map(([lat, lng]) => ({ lat, lng })),
-                    map: map,
-                    fillColor: "#2e7d32", fillOpacity: 0.12, strokeColor: "#2e7d32", strokeWeight: 2,
-                });
-                poly.addListener("click", () => openFarmDetail(farm));
-                return poly;
-            });
-
-            farmMarkers.forEach(m => m.setMap(null));
-            farmMarkers = farms.map(farm => {
-                const marker = new google.maps.Marker({
-                    position: farmCentroid(farm),
-                    title: farm.farm_name || farm.farm_id,
-                });
-                marker.addListener("click", () => {
-                    map.setCenter(farmCentroid(farm));
-                    map.setZoom(SENSOR_ZOOM_THRESHOLD + 2);
-                });
-                return marker;
-            });
-            updateMapZoomView();
-        }
-
-        // --- Farm Detail modal (Edit/Delete, incl. boundary/location redraw) ---
-        const farmDetailModal = document.getElementById("farmDetailModal");
-        let selectedFarmId = null;
-        let farmDetailMapObj = null;
-        let detailVertices = [];
-        let detailVertexMarkers = [];
-        let detailPolygonOverlay = null;
-        let detailHectares = null;
-        let detailEditing = false;
-
-        function redrawDetailShape() {
-            if (detailPolygonOverlay) detailPolygonOverlay.setMap(null);
-            detailVertexMarkers.forEach(m => m.setMap(null));
-            detailVertexMarkers = detailVertices.map(v => new google.maps.Marker({
-                position: v, map: farmDetailMapObj,
-                icon: { path: google.maps.SymbolPath.CIRCLE, scale: 5, fillColor: "#0d631b", fillOpacity: 1, strokeWeight: 0 },
-            }));
-            detailPolygonOverlay = detailVertices.length >= 2
-                ? new google.maps.Polygon({
-                    paths: detailVertices, map: farmDetailMapObj,
-                    fillColor: "#0d631b", fillOpacity: 0.2, strokeColor: "#0d631b", strokeWeight: 2,
-                })
-                : null;
