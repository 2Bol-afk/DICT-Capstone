+def _localize_crop(text: str, crop_en: str, lang: str) -> str:
+    if lang != "fil" or not crop_en:
+        return text
+    fil = CROP_FIL.get(crop_en.lower())
+    if fil:
+        import re
+        text = re.sub(re.escape(crop_en), fil, text, flags=re.IGNORECASE)
+    return text
